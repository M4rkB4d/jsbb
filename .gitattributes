# Default: let Git handle text auto-detection
* text=auto

# Maven wrapper: shell script must stay LF on every platform (POSIX bash chokes on CRLF)
template/compliance-event-logger/base/mvnw text eol=lf
mvnw text eol=lf

# Windows batch wrappers must stay CRLF
template/compliance-event-logger/base/mvnw.cmd text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# SQL migrations: keep LF for cross-platform diff stability
*.sql text eol=lf

# Binary safety
*.jar binary
*.zip binary
