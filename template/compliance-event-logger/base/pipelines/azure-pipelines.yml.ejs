# <%= className %> — build, package, deploy to development on every commit to main.
#
# Stripped-down dev pipeline. The richer per-stage gates (Checkstyle, SonarCloud,
# Trivy) are postponed until your bank's centralized tooling is wired up.
# The stg/prod pipelines are kept on disk but inert until imported as Azure
# DevOps pipelines.

trigger:
  branches:
    include:
      - main

pool: $(pool_name)

variables:
  - group: ServiceConnections
  - group: ApplicationSecrets

  - name: imageName
    value: '<%= projectName %>'
  - name: namespace
    value: '<%= projectName %>'
  - name: majorVersion
    value: '1'
  - name: minorVersion
    value: '0'
  - name: patchVersion
    value: '0'

  - name: non_prod_pool_name
    value: 'Default'

stages:
  - stage: Build
    displayName: Build & Package
    jobs:
      - job: Build
        displayName: Maven Build
        pool:
          vmImage: ubuntu-latest
        steps:
          - checkout: self
            fetchDepth: 0

          - task: DownloadSecureFile@1
            name: settingsXml
            inputs:
              secureFile: settings.xml

          - task: CopyFiles@2
            displayName: 'Copy settings.xml'
            inputs:
              SourceFolder: '$(Agent.TempDirectory)'
              Contents: settings.xml
              TargetFolder: '$(System.DefaultWorkingDirectory)'
              OverWrite: true

          - task: Cache@2
            displayName: 'Cache Maven dependencies'
            inputs:
              key: 'maven | "$(Agent.OS)" | pom.xml'
              restoreKeys: |
                maven | "$(Agent.OS)"
                maven
              path: $(Pipeline.Workspace)/.m2/repository

          - task: Maven@4
            displayName: 'Maven Build (skip ITs in CI)'
            inputs:
              mavenPomFile: 'pom.xml'
              options: '-s $(System.DefaultWorkingDirectory)/settings.xml'
              mavenOptions: '-Xmx3072m -Dmaven.repo.local=$(Pipeline.Workspace)/.m2/repository'
              javaHomeOption: 'JDKVersion'
              jdkVersionOption: '1.<%= javaVersion %>'
              jdkArchitectureOption: 'x64'
              publishJUnitResults: true
              testResultsFiles: '**/surefire-reports/TEST-*.xml'
              # Integration tests need Docker (Testcontainers) which agents may not allow.
              # Run them locally with `mvnw verify`.
              goals: 'clean jacoco:prepare-agent install jacoco:report -Dspring.profiles.active=test -DskipITs -Dcheckstyle.skip=true'

          - publish: $(System.DefaultWorkingDirectory)/target
            artifact: binaries-$(Build.BuildId)

  - stage: GeneratePushImageDev
    displayName: Build & Push Docker Image (Development)
    dependsOn: Build
    condition: succeeded('Build')
    jobs:
      - job: Generate
        displayName: Build & Push (Development)
        pool:
          name: $(non_prod_pool_name)
          vmImage: ubuntu-latest
        steps:
          - checkout: self

          - task: DownloadSecureFile@1
            name: settingsXml
            inputs:
              secureFile: settings.xml

          - task: CopyFiles@2
            displayName: 'Copy settings.xml'
            inputs:
              SourceFolder: '$(Agent.TempDirectory)'
              Contents: settings.xml
              TargetFolder: '$(System.DefaultWorkingDirectory)'
              OverWrite: true

          - task: Docker@2
            displayName: Build Docker Image
            inputs:
              command: build
              repository: $(imageName)
              dockerfile: ./Dockerfile
              buildContext: $(System.DefaultWorkingDirectory)
              containerRegistry: $(docker_registry_servcon_dev)
              tags: |
                $(majorVersion).$(minorVersion).$(patchVersion)-build.$(Build.BuildId)

          - task: Docker@2
            displayName: Push Docker Image
            inputs:
              command: push
              repository: $(imageName)
              containerRegistry: $(docker_registry_servcon_dev)
              tags: |
                $(majorVersion).$(minorVersion).$(patchVersion)-build.$(Build.BuildId)

  - stage: DeployDev
    displayName: Deploy to Kubernetes (Development)
    dependsOn: GeneratePushImageDev
    condition: succeeded('GeneratePushImageDev')
    jobs:
      - deployment: Deploy
        displayName: Deploy (Development)
        pool:
          name: $(non_prod_pool_name)
          vmImage: ubuntu-latest
        environment: <%= projectName %>-development
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self

                - task: ReplaceTokens@3
                  displayName: 'Replace tokens'
                  inputs:
                    targetFiles: '$(System.DefaultWorkingDirectory)/helm/values/development/app.yaml'
                    encoding: 'auto'
                    tokenRegex: '\\#\\{(.+?)\\}\\#'
                    tokenPrefix: '#{'
                    tokenSuffix: '}#'

                - task: HelmDeploy@0
                  displayName: Deploy Helm Chart
                  inputs:
                    connectionType: 'Kubernetes Service Connection'
                    kubernetesServiceEndpoint: $(kubernetes_servcon_dev)
                    namespace: $(namespace)
                    chartType: 'FilePath'
                    chartPath: './helm'
                    releaseName: '<%= projectName %>'
                    command: 'upgrade'
                    install: true
                    arguments: >-
                      --set image.tag="$(majorVersion).$(minorVersion).$(patchVersion)-build.$(Build.BuildId)"
                      --values ./helm/values/development/specs.yaml
                      --values ./helm/values/development/app.yaml
                      --history-max=3
                      --timeout=5m0s
                      --wait
                      --atomic
