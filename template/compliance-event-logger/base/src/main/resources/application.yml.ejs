# Base application config — overridden per environment by application-{env}.yml.
# Activate an environment with --spring.profiles.active=dev (or via SPRING_PROFILES_ACTIVE).

spring:
  application:
    name: <%= projectName %>

  # Optional per-developer overrides — each developer creates their own
  # `developer.properties` (gitignored) at the project root with their preferred
  # profile + any local secrets. The `optional:` prefix means the app boots
  # cleanly when the file is absent (e.g. inside the production Docker image).
  # Pattern documented at:
  #   https://spring.io/blog/2020/08/14/config-file-processing-in-spring-boot-2-4
  config:
    import: optional:file:./developer.properties

  # Java 21 virtual threads — handle every request on a virtual thread.
  threads:
    virtual:
      enabled: true

  # OAuth2 Resource Server (JWT bearer tokens). Production SecurityConfig
  # requires this in non-test/non-local profiles. Set via env:
  #   OAUTH2_ISSUER_URI=https://your-issuer/realms/<%= projectName %>
  # No default — the app must fail to start if a deployment forgets it.
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: ${OAUTH2_ISSUER_URI:}

  datasource:
    url: jdbc:sqlserver://<%= dbServerName %>:1433;databaseName=AFASA;encrypt=true;trustServerCertificate=true
    username: ${DB_USERNAME:sa}
    password: ${DB_PASSWORD:}
    driver-class-name: com.microsoft.sqlserver.jdbc.SQLServerDriver
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      connection-timeout: 10000
      validation-timeout: 5000

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    baseline-version: 0
    table: flyway_schema_history

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      probes:
        enabled: true
      show-details: when-authorized
  metrics:
    tags:
      application: ${spring.application.name}

# EAPI integration (override per environment)
eapi:
  base-url: <%= eapiBaseUrl %>
  connect-timeout: 5s
  read-timeout: 30s

# Resilience4j — declarative policies referenced by @Retry / @CircuitBreaker / @TimeLimiter
resilience4j:
  retry:
    instances:
      eapi-tpp-rule:
        max-attempts: 3
        wait-duration: 5s
  circuitbreaker:
    instances:
      eapi-default:
        sliding-window-type: COUNT_BASED
        sliding-window-size: 20
        failure-rate-threshold: 50
        wait-duration-in-open-state: 30s
        permitted-number-of-calls-in-half-open-state: 5
  timelimiter:
    instances:
      eapi-default:
        timeout-duration: 30s

# Springdoc / OpenAPI
springdoc:
  api-docs:
    path: /v3/api-docs
  swagger-ui:
    path: /swagger-ui.html

logging:
  level:
    root: INFO
    <%= packageName %>: DEBUG
    org.springframework.security: INFO
