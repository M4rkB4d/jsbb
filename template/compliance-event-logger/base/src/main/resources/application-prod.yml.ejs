# Production environment overrides
spring:
  datasource:
    url: jdbc:sqlserver://${DB_SERVER}:1433;databaseName=AFASA;encrypt=true
    hikari:
      maximum-pool-size: ${HIKARI_MAX_POOL:50}
      minimum-idle: ${HIKARI_MIN_IDLE:10}

  # OAuth2 issuer URI is mandatory in prod — no default. App refuses to start without it.
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: ${OAUTH2_ISSUER_URI}

management:
  endpoint:
    health:
      show-details: never  # do not expose details in prod

logging:
  level:
    root: WARN
    <%= packageName %>: INFO

eapi:
  base-url: ${EAPI_URL}  # mandatory env var in prod
