package <%= packageName %>.config;

import net.javacrumbs.shedlock.spring.annotation.EnableSchedulerLock;
import org.springframework.context.annotation.Configuration;
import org.springframework.context.annotation.Profile;
import org.springframework.scheduling.annotation.EnableScheduling;

/**
 * Activates @Scheduled and ShedLock — disabled under the "test" profile so IT
 * runs aren't fighting scheduled jobs for Hikari connections while controllers
 * are being exercised. Production pods always run with this enabled.
 */
@Configuration
@Profile("!test")
@EnableScheduling
@EnableSchedulerLock(defaultLockAtMostFor = "PT15M")
public class SchedulingConfig {
}
