package <%= packageName %>.config;

import io.swagger.v3.oas.models.OpenAPI;
import io.swagger.v3.oas.models.Components;
import io.swagger.v3.oas.models.info.Info;
import io.swagger.v3.oas.models.security.SecurityScheme;
import io.swagger.v3.oas.models.servers.Server;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import java.util.List;

/**
 * Top-level OpenAPI document configuration.
 * Surface served at /swagger-ui.html (UI) and /v3/api-docs (raw spec).
 */
@Configuration
public class OpenApiConfig {

    private static final String BEARER_KEY = "bearerAuth";

    @Bean
    public OpenAPI <%= projectName %>OpenAPI() {
        return new OpenAPI()
            .info(new Info()
                .title("<%= className %> — Compliance Event Logger")
                .description("Generated by jsbb. Update this description before first review.")
                .version("1.0.0"))
            .servers(List.of(
                new Server().url("/api/v1").description("<%= projectName %> v1")
            ))
            .components(new Components()
                .addSecuritySchemes(BEARER_KEY, new SecurityScheme()
                    .type(SecurityScheme.Type.HTTP)
                    .scheme("bearer")
                    .bearerFormat("JWT")
                    .description("OAuth2 JWT bearer token (scope claim required)")));
    }
}
